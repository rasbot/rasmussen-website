---
import ProjectCard from "../components/ProjectCard.astro";
import { getProjectsByCategory, projectCategories } from "../data/projects";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Portfolio"
  description="Portfolio examples for custom 3D printed awards, medals, props, and display pieces."
>
  <section class="section-tight">
    <div class="container stack" style="padding-top: 20px;">
      <p class="eyebrow">Portfolio</p>
      <h1 style="font-size: 52px; line-height: 1.02; max-width: 18ch;">
        Selected work by category.
      </h1>
      <p class="lead" style="max-width: 64ch;">
        Representative projects, not every object that comes off the printer. The goal is to
        show the range of work, the level of finish, and the kinds of problems each category
        is suited for.
      </p>
    </div>
  </section>

  {
    projectCategories.map((category, index) => {
      const categoryProjects = getProjectsByCategory(category.id);
      if (categoryProjects.length === 0) {
        return null;
      }
      const useCompactGrid = category.compact && categoryProjects.length > 1;

      return (
        <section class="portfolio-category">
          <div class="container">
            <div class="portfolio-category-heading">
              <h2>
                <span class="cat-index">0{index + 1}</span>
                {category.title}
              </h2>
              <p>{category.intro}</p>
            </div>
            <div class={useCompactGrid ? "project-grid project-grid-compact" : "project-grid"}>
              {categoryProjects.map((project) => (
                <ProjectCard project={project} compact={useCompactGrid} />
              ))}
            </div>
          </div>
        </section>
      );
    })
  }

  <section class="cta-band" style="margin-top: 68px;">
    <div class="container cta-band-inner">
      <h2>Have a project in mind? Send the practical details.</h2>
      <a class="button" href="/contact/">Request a quote →</a>
    </div>
  </section>
</BaseLayout>
