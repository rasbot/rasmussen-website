---
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Portfolio"
  description="Portfolio examples for custom 3D printed awards, medals, props, and display pieces."
>
  <section class="section">
    <div class="container stack">
      <p class="eyebrow">Portfolio</p>
      <h1>Custom awards, props, and display pieces.</h1>
      <p class="lead">
        Placeholder images are in use for now. Real project photos and descriptions can be
        swapped through the shared project data.
      </p>
    </div>
  </section>

  <section class="section-tight">
    <div class="container project-grid">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>
</BaseLayout>
