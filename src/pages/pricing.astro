---
import BaseLayout from "../layouts/BaseLayout.astro";

const pricingComponents = [
  {
    label: "Part 1 · One-time",
    title: "Design & Development",
    description: "Usually a one-time cost to prepare a new production-ready design.",
    items: [
      "Concept discussion",
      "CAD modeling",
      "Prototypes",
      "Revisions",
      "Print preparation",
    ],
  },
  {
    label: "Part 2 · Per piece",
    title: "Production",
    description: "The per-piece cost for making the final quantity.",
    items: ["3D printing", "Materials", "Painting", "Assembly", "Packaging"],
  },
];

const exampleRows = [
  {
    project: "Two custom awards",
    design: "$150",
    production: "2 × $25",
    total: "~$200",
  },
  {
    project: "Ten custom awards",
    design: "$150",
    production: "10 × $25",
    total: "~$400",
  },
  {
    project: "Production-ready 3D model, ten awards",
    design: "Included",
    production: "10 × $25",
    total: "~$250",
  },
];
---

<BaseLayout
  title="Pricing"
  description="Transparent pricing examples for custom design, 3D printing, painting, finishing, and assembly."
>
  <section class="container split">
    <div>
      <p class="eyebrow">Pricing</p>
      <h1>How custom projects are priced.</h1>
    </div>
    <p class="lead">
      Pricing usually has two parts: the upfront work required to prepare the design,
      and the production cost for the number of finished pieces being made.
    </p>
  </section>

  <section class="container pricing-component-grid">
    {
      pricingComponents.map((component) => (
        <article class="pricing-component">
          <p class="panel-label">{component.label}</p>
          <h2>{component.title}</h2>
          <p>{component.description}</p>
          <ul class="tick-list">
            {component.items.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      ))
    }
  </section>

  <section class="pricing-band">
    <div class="container">
      <div class="section-heading">
        <div class="stack" style="gap: 12px;">
          <p class="eyebrow eyebrow-plain">[ Examples ]</p>
          <h2>Example pricing model.</h2>
        </div>
        <p>These numbers are examples only — they show the structure, not a fixed price list.</p>
      </div>

      <div class="pricing-table-wrap" aria-label="Example custom project pricing">
        <table class="pricing-table">
          <thead>
            <tr>
              <th scope="col">Example project</th>
              <th scope="col">Design &amp; dev</th>
              <th scope="col">Production</th>
              <th scope="col">Est. total</th>
            </tr>
          </thead>
          <tbody>
            {
              exampleRows.map((row) => (
                <tr>
                  <th scope="row">{row.project}</th>
                  <td>{row.design}</td>
                  <td>{row.production}</td>
                  <td>{row.total}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>

      <div class="pricing-note-grid">
        <aside class="panel">
          <h3>What changes the estimate</h3>
          <p>
            Every project is unique, so final pricing depends on complexity, materials,
            print time, painting, finishing, and assembly. This table is intended to
            illustrate how estimates are usually structured rather than serve as a
            fixed price list.
          </p>
        </aside>
        <aside class="panel">
          <h3>Future orders</h3>
          <p>
            Once a 3D-modeled design has been created and tested, future orders of the
            same design are often less expensive because the initial design and prototyping
            work has already been completed. A sketch, logo, photo, or reference image can
            help guide the project, but it usually still requires design and development
            work before production.
          </p>
        </aside>
      </div>
    </div>
  </section>

  <section class="cta-band" style="background: var(--bg);">
    <div class="container cta-band-inner">
      <h2>Want an estimate for your project?</h2>
      <a class="button" href="/contact/">Request a quote →</a>
    </div>
  </section>
</BaseLayout>
