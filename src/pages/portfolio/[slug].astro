---
import { getProjectBySlug, projectCategories, projects } from "../../data/projects";
import BaseLayout from "../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
  }));
}

const project = getProjectBySlug(Astro.params.slug ?? "");

if (!project) {
  return Astro.redirect("/portfolio/");
}

const heroImage = project.heroImage ?? project.coverImage;
const category = projectCategories.find((c) => c.id === project.category);
const gallery = (project.gallery ?? []).filter((image) => image.src !== heroImage);
---

<BaseLayout title={project.title} description={project.summary}>
  <article>
    <section class="container project-detail-hero">
      <div class="stack">
        <a class="back-link" href="/portfolio/">← Portfolio / {category?.title ?? "All work"}</a>
        <h1>{project.title}.</h1>
        <p class="lead">{project.description}</p>
      </div>
      <figure class="figure-frame">
        <div class="figure-clip">
          <img src={heroImage} alt={project.alt} width="1200" height="900" />
        </div>
        <figcaption>
          <span><span class="fig-label">FIG. 01</span> — {project.title}</span>
          {
            project.heroCredit ? (
              <span>
                Photo:{" "}
                <a href={project.heroCredit.url} target="_blank" rel="noreferrer">
                  {project.heroCredit.name}
                </a>
              </span>
            ) : (
              <span>{category?.title}</span>
            )
          }
        </figcaption>
      </figure>
    </section>

    <section class="detail-panels">
      <div class="detail-panels-inner">
        <div class="detail-panel">
          <p class="panel-label">[ Design challenges ]</p>
          <ul class="dash-list">
            {project.challenges.map((challenge) => <li>{challenge}</li>)}
          </ul>
        </div>
        {
          project.fabrication && (
            <div class="detail-panel">
              <p class="panel-label">[ Fabrication notes ]</p>
              <p>{project.fabrication}</p>
            </div>
          )
        }
        <div class="detail-panel">
          <p class="panel-label">[ Final outcome ]</p>
          <p>{project.outcome}</p>
        </div>
      </div>
    </section>

    {
      gallery.length > 0 && (
        <section class="container gallery-section">
          <p class="eyebrow eyebrow-plain">[ Gallery ]</p>
          <h2>Project images.</h2>
          <div class="gallery-grid">
            {gallery.map((image, index) => (
              <figure>
                <div class="figure-clip">
                  <img src={image.src} alt={project.alt} loading="lazy" />
                </div>
                <figcaption>
                  <span class="fig-label">FIG. 0{index + 2}</span> — {image.caption}
                </figcaption>
              </figure>
            ))}
          </div>
        </section>
      )
    }

    <section class="cta-band">
      <div class="container cta-band-inner">
        <h2>Want something built at this level of finish?</h2>
        <a class="button" href="/contact/">Request a quote →</a>
      </div>
    </section>
  </article>
</BaseLayout>
