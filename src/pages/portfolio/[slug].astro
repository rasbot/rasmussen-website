---
import { getProjectBySlug, projects } from "../../data/projects";
import BaseLayout from "../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
  }));
}

const project = getProjectBySlug(Astro.params.slug ?? "");

if (!project) {
  return Astro.redirect("/portfolio/");
}

const gallery = project.gallery?.length ? project.gallery : [project.image];
---

<BaseLayout title={project.title} description={project.summary}>
  <article>
    <section class="section">
      <div class="container project-detail-hero">
        <div class="stack">
          <p class="eyebrow">Portfolio</p>
          <h1>{project.title}</h1>
          <p class="lead">{project.description}</p>
        </div>
        <figure class="project-detail-media">
          <img src={project.image} alt={project.alt} width="1200" height="1200" />
        </figure>
      </div>
    </section>

    <section class="section-tight">
      <div class="container project-detail-grid">
        <section class="panel stack">
          <h2>Design challenges</h2>
          <ul class="list">
            {project.challenges.map((challenge) => <li>{challenge}</li>)}
          </ul>
        </section>

        {
          project.fabrication && (
            <section class="panel stack">
              <h2>Materials / fabrication notes</h2>
              <p>{project.fabrication}</p>
            </section>
          )
        }

        <section class="panel stack">
          <h2>Final outcome</h2>
          <p>{project.outcome}</p>
        </section>
      </div>
    </section>

    <section class="section-tight">
      <div class="container">
        <div class="section-heading">
          <div>
            <p class="eyebrow">Gallery</p>
            <h2>Project images</h2>
          </div>
        </div>
        <div class="project-detail-gallery">
          {gallery.map((image) => <img src={image} alt={project.alt} loading="lazy" />)}
        </div>
      </div>
    </section>
  </article>
</BaseLayout>
