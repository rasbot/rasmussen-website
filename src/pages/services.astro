---
import BaseLayout from "../layouts/BaseLayout.astro";

const services = [
  {
    title: "Custom Design",
    description:
      "Project-specific forms, layouts, modifications, and details tailored to the final use.",
  },
  {
    title: "Prototyping",
    description:
      "Early versions, test prints, fit checks, and practical adjustments before the final build.",
  },
  {
    title: "3D Printing",
    description:
      "Print planning, material choices, and production for one-off pieces and small batches.",
  },
  {
    title: "Painting & Finishing",
    description:
      "Sanding, painting, surface treatment, hardware, and presentation details.",
  },
  {
    title: "Assembly",
    description:
      "Multi-part builds, mounting, joining, and final preparation so the piece is ready to hand over.",
  },
];

const serviceProgression = [
  {
    title: "Model",
    image: "/images/services/model.jpg",
    alt: "Digital model prepared for a custom project.",
  },
  {
    title: "Print",
    image: "/images/services/print.jpg",
    alt: "3D printed parts in progress.",
  },
  {
    title: "Assemble",
    image: "/images/services/assemble.jpg",
    alt: "Custom pieces being assembled.",
  },
  {
    title: "Complete",
    image: "/images/services/complete.jpg",
    alt: "Finished custom piece ready for delivery.",
  },
];
---

<BaseLayout
  title="Services"
  description="Custom 3D printed awards, props, display pieces, and design-for-3D-printing services."
>
  <section class="section">
    <div class="container split">
      <div class="stack">
        <p class="eyebrow">Services</p>
        <h1>Design, print, finish, and assemble.</h1>
      </div>
      <p class="lead">
        Custom awards and display pieces usually need more than a print file. The work can
        include concepting, modeling, test prints, production, paint, finish, and final assembly.
      </p>
    </div>
  </section>

  <section class="section-tight">
    <div class="container service-progression" aria-label="Service process image progression">
      {
        serviceProgression.map((step, index) => (
          <>
            <figure class="service-step">
              <img src={step.image} alt={step.alt} width="900" height="900" loading="lazy" />
              <figcaption>{step.title}</figcaption>
            </figure>
            {index < serviceProgression.length - 1 && (
              <span class="service-arrow" aria-hidden="true">→</span>
            )}
          </>
        ))
      }
    </div>
  </section>

  <section class="section-tight">
    <div class="container service-grid">
      {
        services.map((service) => (
          <article class="service-item">
            <h2>{service.title}</h2>
            <p>{service.description}</p>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
