---
import BaseLayout from "../layouts/BaseLayout.astro";

const services = [
  {
    title: "Custom Design",
    description:
      "Project-specific forms, layouts, and details instead of downloaded files or generic templates.",
  },
  {
    title: "Prototyping",
    description:
      "Early versions, test prints, fit checks, and practical adjustments before the final build.",
  },
  {
    title: "3D Printing",
    description:
      "Print planning, material choices, and production for one-off pieces and small batches.",
  },
  {
    title: "Painting & Finishing",
    description:
      "Sanding, painting, surface treatment, hardware, and presentation details.",
  },
  {
    title: "Assembly",
    description:
      "Multi-part builds, mounting, joining, and final preparation so the piece is ready to hand over.",
  },
];
---

<BaseLayout
  title="Services"
  description="Custom 3D printed awards, props, display pieces, and design-for-3D-printing services."
>
  <section class="section">
    <div class="container split">
      <div class="stack">
        <p class="eyebrow">Services</p>
        <h1>Design, print, finish, and assemble.</h1>
      </div>
      <p class="lead">
        Custom awards and display pieces usually need more than a print file. The work can
        include concepting, modeling, test prints, production, paint, finish, and final assembly.
      </p>
    </div>
  </section>

  <section class="section-tight">
    <div class="container service-grid">
      {
        services.map((service) => (
          <article class="service-item">
            <h2>{service.title}</h2>
            <p>{service.description}</p>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
