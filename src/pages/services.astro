---
import BaseLayout from "../layouts/BaseLayout.astro";

const services = [
  {
    title: "Custom awards",
    description:
      "Trophies, medals, plaques, and branded recognition pieces for competitions, companies, and events.",
  },
  {
    title: "Props and display pieces",
    description:
      "One-off objects, presentation pieces, themed props, and display forms designed for the intended setting.",
  },
  {
    title: "Design for 3D printing",
    description:
      "CAD and print-focused design support for pieces that need to be modeled, adjusted, or prepared for production.",
  },
  {
    title: "Finishing and assembly",
    description:
      "Material selection, printing, sanding, painting, finishing, hardware, and assembly when the project calls for it.",
  },
];
---

<BaseLayout
  title="Services"
  description="Custom 3D printed awards, props, display pieces, and design-for-3D-printing services."
>
  <section class="section">
    <div class="container split">
      <div class="stack">
        <p class="eyebrow">Services</p>
        <h1>Design and production for custom printed objects.</h1>
      </div>
      <p class="lead">
        Projects can be as simple as a small batch of awards or as involved as a custom
        modeled, printed, painted, and assembled display piece.
      </p>
    </div>
  </section>

  <section class="section-tight">
    <div class="container service-grid">
      {
        services.map((service) => (
          <article class="service-item">
            <h2>{service.title}</h2>
            <p>{service.description}</p>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
