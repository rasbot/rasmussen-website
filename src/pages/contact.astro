---
import { site } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";

const contactItems = [
  "Project description",
  "Quantity",
  "Deadline",
  "Budget range",
  "Reference images",
];

const subject = encodeURIComponent("Project inquiry for Nathan Rasmussen Design");
const mailto = `mailto:${site.email}?subject=${subject}`;
---

<BaseLayout
  title="Contact"
  description="Contact Nathan Rasmussen Design for awards, props, display pieces, and fabrication inquiries."
>
  <section class="container contact-grid">
    <div class="stack">
      <p class="eyebrow">Contact</p>
      <h1>Request a quote.</h1>
      <p class="lead">
        Send the practical details first. Scope, quantity, deadline, budget, and reference
        images make it easier to tell what the project will require.
      </p>
      <div class="button-row">
        <a class="button" href={mailto}>Email Nathan Rasmussen Design →</a>
      </div>
      <p style="font-family: var(--font-mono); font-size: 12.5px; color: var(--muted);">
        or write directly: <a href={mailto}>{site.email}</a>
      </p>
    </div>
    <aside class="contact-panel">
      <p class="panel-label">[ Include these details ]</p>
      <ul class="contact-list">
        {contactItems.map((item) => <li>{item}</li>)}
      </ul>
      <p>
        A sketch, logo, photo, or reference image helps guide the project — even if it
        still needs design work before production.
      </p>
    </aside>
  </section>
</BaseLayout>
