---
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects";
import { site } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";

const featuredProjects = projects.slice(0, 3);

const capabilities = [
  {
    title: "Custom Design",
    description: "Original concepts and thoughtful customization.",
  },
  {
    title: "Prototyping",
    description: "Iterative test prints to refine the design.",
  },
  {
    title: "3D Printing",
    description: "High-quality production with tuned settings.",
  },
  {
    title: "Painting & Finishing",
    description: "Surface preparation and finishing.",
  },
  {
    title: "Assembly",
    description: "Final inspection and delivery.",
  },
];
---

<BaseLayout title="Home" description={site.description}>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Nathan Rasmussen Design</p>
        <h1>Custom-designed awards, props, and display pieces.</h1>
        <p class="lead">
          I design, prototype, 3D print, paint, and assemble custom pieces for businesses,
          events, and special projects.
        </p>
        <div class="button-row" aria-label="Primary actions">
          <a class="button" href="/portfolio/">View Portfolio</a>
          <a class="button secondary" href="/contact/">Request a Quote</a>
        </div>
      </div>
      <figure class="hero-media">
        <img
          src="/images/nathan-space-needle.jpg"
          alt="Nathan with a 5.5-foot 3D printed Space Needle."
          width="1200"
          height="800"
        />
      </figure>
    </div>
  </section>

  <section class="section-tight">
    <div class="container section-heading">
      <div>
        <p class="eyebrow">Selected projects</p>
        <h2>Custom work, finished by hand.</h2>
      </div>
      <p>
        Awards, props, and display pieces designed around the client, the event, and the final
        presentation.
      </p>
    </div>
    <div class="container project-grid">
      {featuredProjects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="section">
    <div class="container process-layout">
      <div class="stack">
        <p class="eyebrow">Process</p>
        <h2>More than sending a file to a printer.</h2>
      </div>
      <div class="capability-grid">
        {
          capabilities.map((capability, index) => (
            <>
              <article class="capability-card">
                <h3>{capability.title}</h3>
                <p>{capability.description}</p>
              </article>
              {index < capabilities.length - 1 && <span class="process-arrow" aria-hidden="true">↓</span>}
            </>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section about-band">
    <div class="container about-grid">
      <figure class="about-media">
        <img
          src="/images/portfolio/nathan-printer.jpg"
          alt="Nathan working near a 3D printer."
          width="1200"
          height="800"
          loading="lazy"
        />
      </figure>
      <div class="stack">
        <p class="eyebrow">Hi, I'm Nathan</p>
        <h2>I like making things.</h2>
        <p>
          I design, prototype, 3D print, paint, and assemble custom awards, props, and
          display pieces. Some projects involve original CAD work, some start with adaptation,
          and some depend on careful printing, finishing, and assembly. I care about making
          pieces that feel intentional, polished, and worth keeping.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
