---
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects";
import { site } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";

const featuredProjects = projects.slice(0, 2);
---

<BaseLayout title="Home" description={site.description}>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Custom 3D printed work</p>
        <h1>Awards, props, and display pieces made for real-world moments.</h1>
        <p class="lead">
          Nathan Rasmussen Design creates custom 3D printed awards, branded objects,
          props, display pieces, and print-ready designs for small batches and one-off builds.
        </p>
        <div class="button-row" aria-label="Primary actions">
          <a class="button" href="/portfolio/">View portfolio</a>
          <a class="button secondary" href="/contact/">Start a project</a>
        </div>
      </div>
      <figure class="hero-media">
        <img
          src="/images/robot-awards.svg"
          alt="Placeholder artwork showing a custom robot award concept."
          width="1200"
          height="800"
        />
      </figure>
    </div>
  </section>

  <section class="section-tight">
    <div class="container section-heading">
      <div>
        <p class="eyebrow">Selected work</p>
        <h2>Built to feel specific.</h2>
      </div>
      <p>
        Placeholder images are in use for now. The project data is centralized so real photos
        and descriptions can be swapped in cleanly.
      </p>
    </div>
    <div class="container project-grid">
      {featuredProjects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="section">
    <div class="container split">
      <div class="stack">
        <p class="eyebrow">What this is for</p>
        <h2>Referral-friendly custom design without a heavy agency process.</h2>
      </div>
      <div class="panel stack">
        <p>
          The work starts with a practical idea: a tournament needs an award, a team needs
          a memorable recognition piece, or a display needs an object that does not exist off
          the shelf.
        </p>
        <p>
          From there, the project can include design, 3D modeling, printing, painting,
          finishing, and assembly depending on what the piece needs.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
