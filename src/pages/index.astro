---
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects";
import { site } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";

const featuredProjects = projects.slice(0, 3);

const capabilities = [
  "Custom Design",
  "Prototyping",
  "3D Printing",
  "Painting & Finishing",
  "Assembly",
];
---

<BaseLayout title="Home" description={site.description}>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Nathan Rasmussen Design</p>
        <h1>Custom-designed awards, props, and display pieces.</h1>
        <p class="lead">
          I design, prototype, 3D print, paint, and assemble custom pieces for businesses,
          events, and special projects.
        </p>
        <div class="button-row" aria-label="Primary actions">
          <a class="button" href="/portfolio/">View Portfolio</a>
          <a class="button secondary" href="/contact/">Request a Quote</a>
        </div>
      </div>
      <figure class="hero-media">
        <img
          src="/images/nathan-space-needle.jpg"
          alt="Nathan with a 5.5-foot 3D printed Space Needle."
          width="1200"
          height="800"
        />
      </figure>
    </div>
  </section>

  <section class="section-tight">
    <div class="container section-heading">
      <div>
        <p class="eyebrow">Selected projects</p>
        <h2>Custom work, finished by hand.</h2>
      </div>
      <p>
        Awards, props, and display pieces built around the client, the event, and the final
        presentation.
      </p>
    </div>
    <div class="container project-grid">
      {featuredProjects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="section">
    <div class="container split">
      <div class="stack">
        <p class="eyebrow">Process</p>
        <h2>More than sending a file to a printer.</h2>
      </div>
      <div class="capability-grid">
        {capabilities.map((capability) => <article class="capability-card">{capability}</article>)}
      </div>
    </div>
  </section>

  <section class="section about-band">
    <div class="container about-grid">
      <figure class="about-media">
        <img
          src="/images/portfolio/nathan-printer.jpg"
          alt="Nathan working near a 3D printer."
          width="1200"
          height="800"
          loading="lazy"
        />
      </figure>
      <div class="stack">
        <p class="eyebrow">Hi, I'm Nathan</p>
        <h2>I build custom pieces from scratch.</h2>
        <p>
          I design, prototype, 3D print, paint, and assemble custom awards, props,
          and display pieces. Every project is tailored to the client's needs, from concept
          through the final finish.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
