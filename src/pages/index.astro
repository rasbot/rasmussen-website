---
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects";
import { site } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";

const featuredProjects = projects.slice(0, 3);

const capabilities = [
  {
    title: "Custom Design",
    description: "Project-specific forms, proportions, and details.",
  },
  {
    title: "Prototyping",
    description: "Test prints for fit, scale, and appearance.",
  },
  {
    title: "3D Printing",
    description: "Material choices, print settings, and batch planning.",
  },
  {
    title: "Painting & Finishing",
    description: "Surface prep, color, texture, and final finish.",
  },
  {
    title: "Assembly",
    description: "Joining, cleanup, inspection, and handoff.",
  },
];
---

<BaseLayout title="Home" description={site.description}>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="hero-badge">Available for custom commissions</p>
        <h1>Custom-designed awards, props, and display pieces.</h1>
        <p class="lead">
          I make finished physical pieces for businesses, events, and special projects using
          CAD, 3D printing, paint, and hands-on finishing.
        </p>
        <div class="button-row" aria-label="Primary actions">
          <a class="button" href="/portfolio/">View Portfolio</a>
          <a class="button secondary" href="/contact/">Request a Quote</a>
        </div>
      </div>
      <figure class="hero-media">
        <img
          src="/images/nathan-space-needle.jpg"
          alt="Nathan with a 5.5-foot 3D printed Space Needle."
          width="1200"
          height="800"
        />
      </figure>
    </div>
  </section>

  <section class="section-tight">
    <div class="container section-heading">
      <div>
        <p class="eyebrow">Selected projects</p>
        <h2>Recent work.</h2>
      </div>
      <p>
        A few examples of awards, props, and display pieces made for specific uses,
        settings, and presentation needs.
      </p>
    </div>
    <div class="container project-grid">
      {featuredProjects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading center">
        <div>
          <p class="eyebrow">Process</p>
          <h2>More than sending a file to a printer.</h2>
        </div>
      </div>
      <ol class="process-steps">
        {
          capabilities.map((capability, index) => (
            <li class="process-step">
              <span class="step-num">{String(index + 1).padStart(2, "0")}</span>
              <h3>{capability.title}</h3>
              <p>{capability.description}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="section about-band">
    <div class="container about-grid">
      <figure class="about-media">
        <img
          src="/images/portfolio/nathan-printer.jpg"
          alt="Nathan working near a 3D printer."
          width="1200"
          height="800"
          loading="lazy"
        />
      </figure>
      <div class="stack">
        <p class="eyebrow">Hi, I'm Nathan</p>
        <h2>Designer, printer, and hands-on finisher.</h2>
        <p>
          I work across the digital and physical parts of a project: modeling, print planning,
          test pieces, cleanup, paint, and assembly. Some jobs need original CAD work, some need
          careful modification, and some are mostly about execution and finish. The goal is always
          a piece that looks considered when it leaves the workshop.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
